{
  "name": "@zigai/pi-extension-settings",
  "version": "0.2.8",
  "private": true,
  "description": "TypeBox-first configuration runtime and artifact tooling for Pi extensions.",
  "keywords": [
    "configuration",
    "json-schema",
    "pi-coding-agent",
    "pi-extension",
    "typebox",
    "typescript"
  ],
  "homepage": "https://github.com/zigai/pi-extension-settings#readme",
  "bugs": {
    "url": "https://github.com/zigai/pi-extension-settings/issues"
  },
  "license": "MIT",
  "author": "zigai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zigai/pi-extension-settings.git"
  },
  "bin": {
    "pi-extension-settings": "./dist/cli-entry.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./pi": {
      "types": "./dist/pi.d.ts",
      "import": "./dist/pi.js"
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:check": "npm run build && node scripts/check-dist.ts",
    "lint": "oxlint -c ./.oxlintrc.json .",
    "lint:fix": "oxlint -c ./.oxlintrc.json . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run build:check && npm run coverage",
    "verify": "npm run check",
    "prepack": "npm run build"
  },
  "dependencies": {
    "better-result": "^2.9.2"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.9",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.24.0",
    "typebox": "^1.3.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "bundledDependencies": [
    "better-result"
  ],
  "engines": {
    "node": ">=22.19.0 <27"
  },
  "packageManager": "npm@11.0.0"
}
